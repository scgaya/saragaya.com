---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Thoughts Overflow">
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Thoughts Overflow",
      description:
        "Sharing the thoughts and ideas stuck in my head. Covering anything and everything.",
      url: Astro.site?.href,
    })}
  />
  <section class="blog">
    <header class="blog-header">
      <Heading as="h1">Thoughts Overflow</Heading>
      <p class="blog-tagline">
        Sharing the thoughts and ideas stuck in my head. Covering anything and
        everything.
      </p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="post-item">
              <a href={`/posts/${post.id}`}>
                <span class="post-title">{post.data.title}</span>
                <span class="post-description">{post.data.description}</span>
                <time datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>

<style>
  .blog-header {
    margin-bottom: var(--space-lg);
  }

  .blog-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size);
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-item a:hover .post-title {
    color: var(--color-text-secondary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-blog-title);
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }
</style>
