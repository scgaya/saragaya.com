---
import ThemeButton from "./ThemeButton.astro";

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a href="/" class="nav-brand">
    <span class="home-link"> Sara Gaya </span>
  </a>
  <div class="nav-links">
    <a
      href="/blog"
      class:list={[
        { active: currentPath === "/blog" || currentPath === "/blog/" },
      ]}>Blog</a
    >
    <a href="/rss.xml">RSS</a>
    <a
      href="/search"
      class:list={[
        { active: currentPath === "/search" || currentPath === "/search/" },
      ]}>Search</a
    >
    <ThemeButton />
  </div>
</nav>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-md);
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-text-secondary);
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text);
  }

  .home-link {
    background-image: linear-gradient(
      45deg,
      var(--color-gradient-1),
      var(--color-gradient-2)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    transition:
      var(--color-gradient-1) 0.2s ease-out,
      var(--color-gradient-2) 0.2s ease-in-out;
  }

  @media screen and (min-width: 730px) {
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: var(--space-lg) 0;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: var(--space-2xl);
    }

    .nav-links {
      display: flex;
      gap: var(--space-lg);
    }
  }
</style>
